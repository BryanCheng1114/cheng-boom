generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  theme     String   @default("dark")
  language  String   @default("en")
}
model Product {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique // Unique product code
  nameZh      String?  // Chinese name translation
  nameMs      String?  // Malay name translation
  description   String
  descriptionZh String?  // Chinese description translation
  descriptionMs String?  // Malay description translation
  videoUrl      String?
  stock       Int      @default(0)
  price       Float
  sellerPrice Float?   // Seller special price
  promotion   Float?
  boxPrice       Float?
  itemsPerBox    Int?
  boxSellerPrice Float?
  boxPromotion   Float?
  bundleQuantity    Int?
  bundlePrice       Float?
  bundleSellerPrice Float?
  bundlePromotion   Float?
  category    String?
  status      String   @default("Live")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      String[]
}

model Category {
  id               String   @id @default(cuid())
  name             String   @unique
  code             String?  @unique
  nameZh           String?  // Chinese name translation
  nameMs           String?  // Malay name translation
  description      String?  @db.Text
  displayOrder     Int?     @default(0)
  image            String?  // Image for homepage display
  status           String   @default("Live") // "Live" or "Hold"
  createdAt        DateTime @default(now())
}

model BusinessSettings {
  id                String   @id @default(cuid())
  businessName      String   @default("Cheng-BOOM")
  logoUrl           String?
  watermarkUrl      String?
  faviconUrl        String?
  primaryColor      String?
  accentColor       String?
  businessType      String?
  ownerName         String?
  address           String?
  phone             String?
  email             String?
  whatsapp          String?
  description       String?
  operatingHours    String?
  facebook          String?
  instagram         String?
  tiktok            String?
  bankTransferImage String?
  tngDuitnowImage   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SellerLevel {
  id               String     @id @default(cuid())
  name             String     @unique
  description      String?    @db.Text
  discountPercent  Float      @default(0)
  freeShipping     Boolean    @default(false)
  prioritySupport  Boolean    @default(false)
  customers        Customer[]
}

model Customer {
  id               String   @id @default(cuid())
  name             String
  phone            String?  @unique
  email            String?  @unique
  password         String?  // Optional for Guests, required for Members/Sellers
  address          String?
  preferredPayment String?
  orderMode        String?  // "Self Collect" or "Delivery"
  deliveryDetails  String?
  notes            String?
  role             String       @default("Guest") // "Guest", "Member", or "Seller"
  sellerLevelId    String?
  sellerLevel      SellerLevel? @relation(fields: [sellerLevelId], references: [id])
  isActive         Boolean      @default(true) // For suspension/activation
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  orders           Order[]
}

model Order {
  id            String      @id @default(cuid())
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    String
  totalAmount   Float
  paymentMethod String?
  deliveryMode  String?
  address       String?
  notes         String?
  status        String      @default("Pending") // "Pending", "Processing", "Completed", "Cancelled"
  paymentReceiptUrl String? // Image URL of the payment receipt
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  variant   String?
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

