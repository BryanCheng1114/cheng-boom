generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  theme     String   @default("dark")
  language  String   @default("en")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  videoUrl    String?
  stock       Int      @default(0)
  price       Float
  promotion   Float?
  category    String?
  status      String   @default("Live")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      String[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  image     String?  // Image for homepage display
  createdAt DateTime @default(now())
}

model Customer {
  id               String   @id @default(cuid())
  name             String
  phone            String   @unique
  password         String?  // Optional for Guests, required for Members/Sellers
  address          String?
  preferredPayment String?
  orderMode        String?  // "Self Collect" or "Delivery"
  deliveryDetails  String?
  notes            String?
  role             String   @default("Guest") // "Guest", "Member", or "Seller"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
}

model Order {
  id            String      @id @default(cuid())
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    String
  totalAmount   Float
  paymentMethod String?
  deliveryMode  String?
  address       String?
  notes         String?
  status        String      @default("Pending") // "Pending", "Processing", "Completed", "Cancelled"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
}
